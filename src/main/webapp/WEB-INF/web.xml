<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>BloodBankManagementSystem</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
  </welcome-file-list>
  
   <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>controller.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- Donor Servlet -->
    <servlet>
        <servlet-name>DonorServlet</servlet-name>
        <servlet-class>controller.DonorServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DonorServlet</servlet-name>
        <url-pattern>/DonorServlet</url-pattern>
    </servlet-mapping>

    <!-- Patient Servlet -->
    <servlet>
        <servlet-name>PatientServlet</servlet-name>
        <servlet-class>controller.PatientServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>PatientServlet</servlet-name>
        <url-pattern>/PatientServlet</url-pattern>
    </servlet-mapping>

    <!-- Blood Stock Servlet -->
    <servlet>
        <servlet-name>BloodStockServlet</servlet-name>
        <servlet-class>controller.BloodStockServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BloodStockServlet</servlet-name>
        <url-pattern>/BloodStockServlet</url-pattern>
    </servlet-mapping>

    <!-- Donation Servlet -->
    <servlet>
        <servlet-name>DonationServlet</servlet-name>
        <servlet-class>controller.DonationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DonationServlet</servlet-name>
        <url-pattern>/DonationServlet</url-pattern>
    </servlet-mapping>

    <!-- Blood Request Servlet -->
    <servlet>
        <servlet-name>BloodRequestServlet</servlet-name>
        <servlet-class>controller.BloodRequestServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BloodRequestServlet</servlet-name>
        <url-pattern>/BloodRequestServlet</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <!-- Session Timeout -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <servlet>
    <servlet-name>DeleteAccountServlet</servlet-name>
    <servlet-class>controller.DeleteAccountServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteAccountServlet</servlet-name>
    <url-pattern>/DeleteAccountServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DashboardServlet</servlet-name>
    <servlet-class>controller.DashboardServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DashboardServlet</servlet-name>
    <url-pattern>/DashboardServlet</url-pattern>
</servlet-mapping>

<!-- User Dashboard Servlet -->
<servlet>
    <servlet-name>UserDashboardServlet</servlet-name>
    <servlet-class>controller.UserDashboardServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>UserDashboardServlet</servlet-name>
    <url-pattern>/UserDashboardServlet</url-pattern>
</servlet-mapping>

<servlet>

<servlet-name>VerifyOTPServlet</servlet-name>

<servlet-class>
controller.VerifyOTPServlet
</servlet-class>

</servlet>



<servlet-mapping>

<servlet-name>VerifyOTPServlet</servlet-name>

<url-pattern>/VerifyOTPServlet</url-pattern>

</servlet-mapping>
</web-app>